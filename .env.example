# API Anahtarları (güvenlik için .env dosyasına taşıyın, .gitignore'da)
# .env.example'ı .env olarak kopyalayıp değerleri doldurun.

# OpenWeatherMap - https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_KEY=your_openweather_api_key

# Google AI (Gemini) - https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GOOGLE_AI_KEY=your_google_ai_key
